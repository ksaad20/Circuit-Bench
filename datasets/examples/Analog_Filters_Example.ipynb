import numpy as np
import pandas as pd
import matplotlib.pyplot as plt

R_values = np.array([100, 220, 470, 1000, 2200])
C_values = np.array([1e-6, 2.2e-6, 4.7e-6])

records = []

for R in R_values:
    for C in C_values:

        cutoff_frequency = 1 / (2 * np.pi * R * C)

        records.append(
            {
                "Resistance_Ohm": R,
                "Capacitance_F": C,
                "Cutoff_Hz": cutoff_frequency,
                "Filter_Type": "RC_Low_Pass",
            }
        )

filter_dataset = pd.DataFrame(records)

filter_dataset.head()

filter_dataset.to_csv(
    "analog_filter_dataset.csv",
    index=False
)
